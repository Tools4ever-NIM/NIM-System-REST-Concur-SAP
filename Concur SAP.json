    "rest": {
        "config": {
            "baseUrl": "{geolocation}",
            "get": {
                "maxPageCount": 5,
                "pagination": {
                    "mode": "url",
                    "replace_in_url": true,
                    "last_page": {
                        "type": "token",
                        "path": "nextCursor"
                    },
                    "query_params": [
                        {
                            "name": "cursor",
                            "value": {
                                "type": "response_field",
                                "value": "nextCursor"
                            }
                        }
                    ]
                }
            },
            "authentication": "password_grant",
            "call_handling": "generic",

            "retry": [
                {
                    "type": "statusCode",
                    "statusCode": 503
                },
                {
                    "type": "connectionError"
                }
            ],
            "test_connection": {
                "url": "/profile/identity/v4.1/Users?count=1"
            },
            "accept": "application/json"
        },
        "authOptions": {
            "type": "password_grant",
            "authUrl": "{geolocation}/oauth2/v0/token",
            "extraTokenRequestData": {
                "credtype": "authtoken"
            },
            "extraParameters": {
                "geolocation": "geolocation"
            }
        }
    },
